# Copy this file to ".env" to customise behaviour. All values are OPTIONAL.
# With no keys set, DocuMind runs fully offline (no API key required).

# Provider: auto | offline | openai | gemini  (auto picks based on keys below)
LLM_PROVIDER=auto

# --- Optional personal API keys (use your OWN free/personal keys) ---
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Model overrides (optional)
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-1.5-flash

# Retrieval tuning (optional)
# CHUNK_SIZE=600
# CHUNK_OVERLAP=100
# TOP_K=4
